# Токен Telegram-бота из @BotFather
BOT_TOKEN=

# Порт API-сервера
PORT=3000

# Dev-вход без Telegram (1 = вкл). В проде оставьте пустым/0.
ALLOW_DEV_AUTH=

# Telegram-id администраторов через запятую (для админки: правка любых профилей)
# Напр.: ADMIN_IDS=123456789,987654321
ADMIN_IDS=

# Supabase (общая БД профилей). Если заданы — хранилище переключается на Supabase,
# иначе используется файловое (server/data/profiles.json).
# URL и SERVICE ROLE key берутся из Supabase → Project Settings → API.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
