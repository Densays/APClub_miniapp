# Пример продакшн-окружения API-сервера. Реальные значения задаются в Render
# (Environment), НЕ коммитить настоящий .env. Скопируй ключи, впиши значения.

# Телеграм-бот
BOT_TOKEN=8702346617:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase (общая БД)
SUPABASE_URL=https://xbbiuavwtcxrwnqlnmgs.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx   # СЕКРЕТНЫЙ ключ (обходит RLS)

# Браузерная админ-панель
ADMIN_PASSWORD=СМЕНИ_МЕНЯ                                  # обязательно сменить!
ADMIN_IDS=322397149                                       # Telegram-id админа(ов), через запятую

# Прод-безопасность
ALLOW_DEV_AUTH=0                                           # 0 в проде! (1 = вход без пароля/Telegram)
PORT=3000

# Ссылки приложения (задать ПОСЛЕ деплоя фронта на Vercel)
MINIAPP_URL=https://apclub.vercel.app                     # web_app-кнопка в личке бота
MINIAPP_LINK=https://t.me/apclubnews_bot/app              # url-кнопка входа в КАНАЛЕ (из BotFather)
MEMORANDUM_URL=                                            # опц.; по умолчанию MINIAPP_URL/onboarding.html

# Канал клуба (для закреплённого приветствия)
CHANNEL_ID=@your_channel                                  # @username или -100xxxxxxxxxx
